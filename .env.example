# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=entropy_admin
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://entropy_admin:change_me_in_production@localhost:5432/entropy_rfp

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant (vector DB) ────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=entropy_minio
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET_NAME=entropy-rfp-documents
MINIO_SECURE=false

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_use_256_bit_random_string_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# ── LLM APIs ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
PRIMARY_LLM_MODEL=claude-opus-4-6
SECONDARY_LLM_MODEL=gpt-4o
COHERE_API_KEY=...
EMBEDDING_MODEL=embed-multilingual-v3.0

# ── OCR ───────────────────────────────────────────────────────────────────────
OCR_PROVIDER=azure
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_azure_key_here

# ── Keycloak (SSO) ────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=entropy
KEYCLOAK_CLIENT_ID=entropy-rfp-platform
KEYCLOAK_CLIENT_SECRET=your_keycloak_secret

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000
API_BASE_URL=http://localhost:8000

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=entropy-rfp-api
